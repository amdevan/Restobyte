generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                 String                @id @default(uuid())
  name               String
  address            String?
  phone              String?
  adminEmail         String?
  countryCode        String? // ISO 3166-1 alpha-2 (e.g., US, IN)
  currencyCode       String? // ISO 4217 (e.g., USD, INR)
  subscriptionStatus String                @default("trialing")
  plan               String                @default("Basic")
  trialDays          Int?                  @default(14)
  trialEndsAt        DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  outlets            Outlet[]
  users              User[]
  roles              Role[]
  payments           Payment[]
  loginHistory       TenantLoginHistory[]
  invoices           SubscriptionInvoice[]
}

model Outlet {
  id                      String    @id @default(uuid())
  name                    String
  restaurantName          String?
  slug                    String    @unique
  outletType              String    @default("Restaurant")
  tenantId                String
  tenant                  Tenant    @relation(fields: [tenantId], references: [id])
  address                 String?
  phone                   String?
  email                   String?
  logoUrl                 String?
  taxes                   Json?
  whatsappNumber          String?
  whatsappOrderingEnabled Boolean   @default(false)
  whatsappDefaultMessage  String?
  fonepayIsEnabled        Boolean   @default(false)
  fonepayMerchantCode     String?
  fonepayTerminalId       String?
  fonepayCurrency         String?
  plan                    String?
  subscriptionStatus      String?
  planExpiryDate          DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  users                   User[]
  orders                  Order[]
  invoices                Invoice[]
  // Categories, Tables, etc. could optionally be linked here too, 
  // but for now we keep the loosely coupled 'outletId' string in those models 
  // to avoid complex migration issues with existing data if any.
  // Actually, let's keep it loose for now to match the previous step's schema
  // unless we want strict referential integrity. 
  // Given the user wants "fresh", strict is better, but 'outletId' string is flexible.
}

model Category {
  id          String     @id @default(uuid())
  name        String
  description String?
  imageUrl    String?
  outletId    String?
  menuItems   MenuItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model MenuItem {
  id           String      @id @default(uuid())
  name         String
  description  String?
  price        Float
  categoryId   String
  category     Category    @relation(fields: [categoryId], references: [id])
  imageUrl     String?
  isAvailable  Boolean     @default(true)
  isVegetarian Boolean     @default(false)
  variations   Variation[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  OrderItem    OrderItem[]
}

model Variation {
  id         String   @id @default(uuid())
  name       String
  price      Float
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Table {
  id                    String        @id @default(uuid())
  name                  String
  capacity              Int
  status                String        @default("Free") // Free, Occupied, Reserved
  outletId              String
  areaFloorId           String?
  notes                 String?
  assistanceRequested   Boolean       @default(false)
  assistanceRequestedAt DateTime?
  foodReady             Boolean       @default(false)
  occupiedSince         DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  reservations          Reservation[]
}

model Customer {
  id                  String    @id @default(uuid())
  name                String
  email               String?
  phone               String?
  address             String?
  billingAddress      String?
  dob                 DateTime?
  companyName         String?
  vatPan              String?
  dueAmount           Float     @default(0)
  totalPurchaseAmount Float     @default(0)
  totalPaidAmount     Float     @default(0)
  lastPaymentDate     DateTime?
  outletId            String?

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  orders           Order[]
  invoices         Invoice[]
  paymentHistories PaymentHistory[]
  reservations     Reservation[]
}

model Order {
  id         String      @id @default(uuid())
  createdAt  DateTime    @default(now())
  customerId String?
  customer   Customer?   @relation(fields: [customerId], references: [id])
  items      OrderItem[]
  total      Float       @default(0)
  status     String      @default("PENDING") // PENDING, COMPLETED, CANCELLED
  outletId   String?
  outlet     Outlet?     @relation(fields: [outletId], references: [id])
  saleData   Json?
  invoices   Invoice[]
}

model OutletAppData {
  id        String   @id @default(uuid())
  outletId  String
  key       String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([outletId, key])
}

model UserAppData {
  id        String   @id @default(uuid())
  userId    String
  key       String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
}

model GlobalAppData {
  id        String   @id @default(uuid())
  key       String   @unique
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  quantity   Int
  unitPrice  Float
}

model User {
  id       String  @id @default(uuid())
  username String  @unique
  email    String? @unique
  phone    String? @unique
  password String
  roleId   String?

  outletId  String?
  outletIds Json?
  outlet    Outlet? @relation(fields: [outletId], references: [id])

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  isActive     Boolean              @default(true)
  isSuperAdmin Boolean              @default(false)
  customer     Customer?
  loginHistory TenantLoginHistory[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

model Currency {
  id           String   @id @default(uuid())
  name         String
  code         String   @unique
  symbol       String
  exchangeRate Float
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PlanDefinition {
  id          String   @id @default(uuid())
  name        String   @unique
  price       Float
  period      String   @default("yearly")
  features    Json?
  featureKeys Json?
  limits      Json?
  trialDays   Int      @default(14)
  isPublic    Boolean  @default(true)
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Role {
  id          String   @id
  name        String
  permissions Json?
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, name])
}

model Payment {
  id        String               @id @default(uuid())
  tenantId  String
  tenant    Tenant               @relation(fields: [tenantId], references: [id])
  amount    Float
  status    String               @default("paid") // paid, failed, refunded
  method    String? // stripe, cash, etc.
  notes     String?
  invoice   SubscriptionInvoice?
  createdAt DateTime             @default(now())
}

model SubscriptionInvoice {
  id            String    @id @default(uuid())
  invoiceNumber String    @unique
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  paymentId     String?   @unique
  payment       Payment?  @relation(fields: [paymentId], references: [id])
  amount        Float
  currencyCode  String    @default("NPR")
  status        String    @default("issued") // issued, paid, failed, refunded
  method        String?
  notes         String?
  issuedAt      DateTime  @default(now())
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Invoice {
  id               String           @id @default(uuid())
  invoiceNumber    String           @unique
  orderId          String
  order            Order            @relation(fields: [orderId], references: [id])
  customerId       String?
  customer         Customer?        @relation(fields: [customerId], references: [id])
  outletId         String
  outlet           Outlet           @relation(fields: [outletId], references: [id])
  totalAmount      Float            @default(0)
  paidAmount       Float            @default(0)
  dueAmount        Float            @default(0)
  paymentStatus    String           @default("DUE") // DUE, PARTIAL, PAID
  paymentMethod    String?
  items            Json?
  taxAmount        Float            @default(0)
  discountAmount   Float            @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  paidAt           DateTime?
  paymentHistories PaymentHistory[]
}

model PaymentHistory {
  id         String    @id @default(uuid())
  invoiceId  String
  invoice    Invoice   @relation(fields: [invoiceId], references: [id])
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  amount     Float
  method     String
  createdAt  DateTime  @default(now())
}

model TenantLoginHistory {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  username    String
  ipAddress   String?
  userAgent   String?
  deviceLabel String?
  loginType   String   @default("password")
  createdAt   DateTime @default(now())
}

model Lead {
  id        String     @id @default(uuid())
  name      String
  email     String?
  phone     String?
  company   String?
  source    String?
  stage     String     @default("New")
  notes     LeadNote[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model LeadNote {
  id        String   @id @default(uuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id])
  content   String
  createdAt DateTime @default(now())
}

model SaasEmailConfig {
  id         String   @id @default(uuid())
  env        String   @default("dev")
  provider   String?
  smtpHost   String?
  smtpPort   Int?
  smtpSecure Boolean?
  smtpUser   String?
  smtpPass   String?
  fromName   String?
  fromEmail  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([env])
}

model SaasWebsiteContent {
  id        String   @id @default(uuid())
  env       String   @default("default")
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([env])
}

model Reservation {
  id              String   @id @default(uuid())
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id])
  tableId         String?
  table           Table?   @relation(fields: [tableId], references: [id])
  outletId        String
  reservationTime DateTime
  numberOfGuests  Int
  status          String   @default("PENDING")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
